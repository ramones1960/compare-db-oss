# 共通環境変数のサンプル。コピーして .env を作成して利用する。
#   cp .env.example .env

# --- 共通認証情報（検証用。本番では使用しないこと） ---
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=benchdb

# --- ポートマッピング（衝突する場合は変更） ---
POSTGRES_PORT=5432
MYSQL_PORT=3306
MONGODB_PORT=27017
REDIS_PORT=6379
CASSANDRA_PORT=9042
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
COCKROACHDB_PORT=26257
INFLUXDB_PORT=8086
TIMESCALEDB_PORT=5433
OPENSEARCH_PORT=9200
CLICKHOUSE_PORT=8123
QDRANT_PORT=6333
PGVECTOR_PORT=5434

# --- ベンチ共通設定 ---
BENCH_RECORD_COUNT=100000
BENCH_OPERATION_COUNT=100000
BENCH_THREADS=8
