# 共通環境変数のサンプル。コピーして .env を作成して利用する。
#   cp .env.example .env

# --- 共通認証情報（検証用。本番では使用しないこと） ---
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=benchdb

# OpenSearch は強パスワード必須（大小英字・数字・記号）。共通とは別管理。
OPENSEARCH_PASSWORD=Zx9!qWeRt#Uk7mp2

# Neo4j はユーザ名 neo4j 固定・8文字以上のパスワードが必要。
NEO4J_PASSWORD=neo4jPass123

# --- ポートマッピング（衝突する場合は変更） ---
POSTGRES_PORT=5432
MYSQL_PORT=3306
MONGODB_PORT=27017
REDIS_PORT=6379
CASSANDRA_PORT=9042
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
COCKROACHDB_PORT=26257
INFLUXDB_PORT=8086
TIMESCALEDB_PORT=5433
OPENSEARCH_PORT=9200
CLICKHOUSE_PORT=8123
QDRANT_PORT=6333
PGVECTOR_PORT=5434

# --- ベンチ共通設定 ---
BENCH_RECORD_COUNT=100000
BENCH_OPERATION_COUNT=100000
BENCH_THREADS=8

# --- プロキシ（社内プロキシ環境のみ。通常はシェルの環境変数で設定）---
# 詳細・設定方法は docs/proxy.md を参照。NO_PROXY には必ず localhost を含めること。
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,::1
